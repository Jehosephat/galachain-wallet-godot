// Template for WalletDemoGame.LocalSecrets.cs — copy this file to
// `WalletDemoGame.LocalSecrets.cs` (same directory) before testing the allowance
// flow. The real filename is listed in .gitignore so your keys never get committed.
//
// Leave this .example file tracked; it's what reminds future developers that the
// pattern exists.

public partial class WalletDemoGame
{
	partial void LoadLocalSecrets()
	{
		// 64-char hex secp256k1 private key (no 0x prefix is fine; Nethereum accepts either).
		_demoBackendPrivateKey = "PASTE_YOUR_BACKEND_PRIVATE_KEY_HERE";

		// The GalaChain alias that private key corresponds to on chain. This is the
		// identity that will be named as the spender in GrantAllowance DTOs and as
		// the signer of spend-allowance TransferToken DTOs.
		//   - For an unregistered wallet: "eth|<address without 0x prefix>"
		//   - For a registered GalaChain user: "client|<user id>"
		_demoBackendIdentity = "eth|PASTE_CORRESPONDING_ADDRESS_HERE";
	}
}
